  "item": [
    {
      "name": "RBAC (QLDL)",
      "item": [
        {
          "name": "Get Permissions (Catalog)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/permissions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "permissions"
              ]
            },
            "description": "GET /permissions — catalog tĩnh theo docs. JWT + ADMIN_RBAC:READ."
          },
          "response": []
        },
        {
          "name": "List Role Groups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/role-groups",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "role-groups"
              ]
            },
            "description": "GET /role-groups — JWT + ADMIN_RBAC:READ."
          },
          "response": []
        },
        {
          "name": "Create Role Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nhóm quyền test\",\n  \"description\": \"Tạo từ Postman\",\n  \"permissions\": {\n    \"APPROVALS\": [\"READ\",\"WRITE\"],\n    \"ENTRY_SUBMISSIONS\": [\"READ\",\"WRITE\"],\n    \"NOTIFICATIONS\": [\"READ\"]\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/role-groups",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "role-groups"
              ]
            },
            "description": "POST /role-groups — JWT + ADMIN_RBAC:WRITE."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const envelope = pm.response.json();",
                  "  const data = envelope && envelope.data !== undefined ? envelope.data : envelope;",
                  "  if (data && data.id) pm.collectionVariables.set('roleGroupId', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Patch Role Group",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Cập nhật từ Postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/role-groups/{{roleGroupId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "role-groups",
                "{{roleGroupId}}"
              ]
            },
            "description": "PATCH /role-groups/:id — JWT + ADMIN_RBAC:WRITE."
          },
          "response": []
        }
      ],
      "description": "RBAC QLDL: role-groups + permissions catalog"
    }
