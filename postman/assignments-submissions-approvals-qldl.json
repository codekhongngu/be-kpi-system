              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const envelope = pm.response.json();",
                  "  const data = envelope && envelope.data !== undefined ? envelope.data : envelope;",
                  "  if (data && data.id) pm.collectionVariables.set('submissionId', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
