  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Password@123\",\n  \"fullName\": \"Test User\",\n  \"phone\": \"0123456789\",\n  \"code\": \"USR-TEST\",\n  \"orgId\": \"{{orgId}}\",\n  \"roleGroupIds\": [],\n  \"roleIds\": [],\n  \"departmentId\": \"{{departmentId}}\",\n  \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Tạo user mới (yêu cầu JWT)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const envelope = pm.response.json();",
                  "    const jsonData = envelope && envelope.data !== undefined ? envelope.data : envelope;",
                  "    pm.collectionVariables.set('userId', jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Users By Department",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/departments/{{departmentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "departments",
                "{{departmentId}}"
              ]
            },
            "description": "GET /users/departments/:id — danh sách UserListItem. JWT + ADMIN_USERS:READ."
          },
          "response": []
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/activate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "activate"
              ]
            },
            "description": "Kích hoạt user (active + clear lock counters)"
          },
          "response": []
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/deactivate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "deactivate"
              ]
            },
            "description": "Vô hiệu hóa user (inactive)"
          },
          "response": []
        },
        {
          "name": "Reset User Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"Reset@12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "reset-password"
              ]
            },
            "description": "Reset mật khẩu (nếu bỏ body newPassword, server sẽ generate temporaryPassword)"
          },
          "response": []
        },
        {
          "name": "Import Users (CSV)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/import",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "import"
              ]
            },
            "description": "Import CSV async (multipart field `file`). Dòng 1 là header **chữ thường** (khớp parser): `code,fullname,email,username,password,orgid,roleids,status` + **bắt buộc một trong hai**: `rolegroupids` (khuyến nghị) hoặc `rolegroupid` (tương thích ngược). Nhiều UUID trong `rolegroupids` / `rolegroupid` hoặc `roleids`: phân tách bằng `|`. `password` có thể để trống → server sinh mật khẩu. Phản hồi: `{ jobId }` trong envelope `data`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const envelope = pm.response.json();",
                  "    const jsonData = envelope && envelope.data !== undefined ? envelope.data : envelope;",
                  "    pm.collectionVariables.set('importJobId', jsonData.jobId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Import Job Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/import/{{importJobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "import",
                "{{importJobId}}"
              ]
            },
            "description": "Xem kết quả import (status + errors theo dòng)"
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=10&q=&search=&status=&isActive=&orgId=&roleGroupId=&roleId=&departmentId=&sort=createdAt,desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Số trang (mặc định: 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Số lượng items mỗi trang (mặc định: 10)"
                },
                {
                  "key": "q",
                  "value": "",
                  "description": "Alias search (username/email/fullName/code)"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Tìm kiếm theo username, email, fullName, code"
                },
                {
                  "key": "status",
                  "value": "",
                  "description": "Lọc enum nội bộ: active | inactive | suspended (tuỳ chọn; để trống = không lọc)"
                },
                {
                  "key": "isActive",
                  "value": "",
                  "description": "QLDL: true | false (ưu tiên contract; khác `status`)"
                },
                {
                  "key": "orgId",
                  "value": "",
                  "description": "Lọc theo đơn vị (users.org_id)"
                },
                {
                  "key": "roleGroupId",
                  "value": "",
                  "description": "Lọc theo nhóm quyền QLDL (primary hoặc user_role_groups)"
                },
                {
                  "key": "roleId",
                  "value": "{{roleIdFilter}}",
                  "description": "Lọc theo role (Nest roles.id)"
                },
                {
                  "key": "departmentId",
                  "value": "",
                  "description": "Lọc theo department ID"
                },
                {
                  "key": "sort",
                  "value": "createdAt,desc",
                  "description": "Ví dụ: createdAt,desc | username,asc"
                }
              ]
            },
            "description": "GET /users — { items: UserListItem[], meta } (QLDL). JWT + quyền ADMIN_USERS:READ trên role_groups.permissions."
          },
          "response": []
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}"
              ]
            },
            "description": "GET /users/:id — UserDetail (QLDL). JWT + ADMIN_USERS:READ."
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"updateduser\",\n  \"email\": \"updated@example.com\",\n  \"fullName\": \"Updated User\",\n  \"phone\": \"0987654321\",\n  \"departmentId\": \"{{departmentId}}\",\n  \"status\": \"active\",\n  \"password\": \"NewPass@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Cập nhật thông tin user (yêu cầu JWT)"
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}"
              ]
            },
            "description": "Xóa user (yêu cầu JWT)"
          },
          "response": []
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "status"
              ]
            },
            "description": "Cập nhật status của user: active, inactive, suspended (yêu cầu JWT)"
          },
          "response": []
        },
        {
          "name": "Get User Permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/permissions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "permissions"
              ]
            },
            "description": "Lấy permissions của user (từ Nest roles)"
          },
          "response": []
        },
        {
          "name": "Assign Roles to User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleIds\": [\"{{roleIdFilter}}\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/roles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "roles"
              ]
            },
            "description": "Gán roles (Nest) cho user"
          },
          "response": []
        }
      ],
      "description": "User management endpoints"
    }
  ]
}