    {
      "key": "importJobId",
      "value": "",
      "type": "string"
    },
    {
      "key": "roleIdFilter",
      "value": "",
      "type": "string"
    },
    {
      "key": "roleGroupId",
      "value": "",
      "type": "string"
    },
    {
      "key": "formId",
      "value": "",
      "type": "string"
