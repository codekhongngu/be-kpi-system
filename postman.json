							"raw": "{{baseUrl}}/api/v1/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["api","v1","auth", "me"]
						},
						"description": "GET /auth/me — hợp đồng MeResponse (QLDL): id, code, fullName, email, username, phone, avatarUrl, orgId, roleGroupIds[], language, timezone, notifyChannel. JWT bắt buộc; body nằm trong envelope `data`."
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const envelope = pm.response.json();",
									"    const jsonData = envelope && envelope.data !== undefined ? envelope.data : envelope;",
									"    pm.collectionVariables.set('userId', jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
