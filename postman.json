      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "let res = {};",
                  "try { res = pm.response.json(); } catch (e) { res = {}; }",
                  "const payload = (res && res.data) ? res.data : res;",
                  "const token = payload?.accessToken || payload?.access_token || payload?.token;",
                  "const refreshToken = payload?.refreshToken || payload?.refresh_token;",
                  "const user = payload?.user || {};",
                  "if (token) pm.collectionVariables.set('accessToken', token);",
                  "if (refreshToken) pm.collectionVariables.set('refreshToken', refreshToken);",
                  "if (user?.id) pm.collectionVariables.set('userId', user.id);",
                  "pm.test('Access token saved', function () { pm.expect(pm.collectionVariables.get('accessToken')).to.not.eql(''); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
