{
  "info": {
    "_postman_id": "f6ce7560-c32f-4baf-9a51-0ce2e35c990f",
    "name": "BE KPI System API",
    "description": "Collection generated from current NestJS module/controller structure. Global prefix: /api/v1. Use Auth/Login first to auto-save bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "permissionId", "value": "" },
    { "key": "orgId", "value": "" },
    { "key": "formId", "value": "" },
    { "key": "fieldCategoryId", "value": "" },
    { "key": "indicatorId", "value": "" },
    { "key": "attrId", "value": "" },
    { "key": "submissionId", "value": "" },
    { "key": "campaignId", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "batchId", "value": "" },
    { "key": "summaryId", "value": "" },
    { "key": "notificationId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "let res = {};",
                  "try { res = pm.response.json(); } catch (e) { res = {}; }",
                  "const payload = (res && res.data) ? res.data : res;",
                  "const token = payload?.accessToken || payload?.access_token || payload?.token;",
                  "const refreshToken = payload?.refreshToken || payload?.refresh_token;",
                  "const user = payload?.user || {};",
                  "if (token) pm.collectionVariables.set('accessToken', token);",
                  "if (refreshToken) pm.collectionVariables.set('refreshToken', refreshToken);",
                  "if (user?.id) pm.collectionVariables.set('userId', user.id);",
                  "pm.test('Access token saved', function () { pm.expect(pm.collectionVariables.get('accessToken')).to.not.eql(''); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"admin@localhost.local\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        { "name": "Register", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"username\": \"newuser\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Admin@123\",\n  \"fullName\": \"New User\",\n  \"orgId\": \"{{orgId}}\"\n}" }, "url": "{{baseUrl}}/auth/register" } },
        { "name": "Refresh Token", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }, "url": "{{baseUrl}}/auth/refresh-token" } },
        { "name": "Me", "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" } },
        { "name": "Change Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"Admin@123\",\n  \"newPassword\": \"Admin@1234\"\n}" }, "url": "{{baseUrl}}/auth/change-password" } },
        { "name": "Forgot Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@localhost.local\"\n}" }, "url": "{{baseUrl}}/auth/forgot-password" } },
        { "name": "Reset Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"token\": \"paste-reset-token\",\n  \"newPassword\": \"Admin@1234\"\n}" }, "url": "{{baseUrl}}/auth/reset-password" } },
        { "name": "Logout", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }, "url": "{{baseUrl}}/auth/logout" } }
      ]
    },
