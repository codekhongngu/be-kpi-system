						"description": "Làm mới access token bằng refresh token (rotate: refreshToken sẽ được cấp mới)"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const envelope = pm.response.json();",
