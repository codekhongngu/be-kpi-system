							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api","v1","auth", "logout"]
						},
						"description": "Đăng xuất (yêu cầu JWT). Nếu gửi refreshToken sẽ revoke đúng session; nếu không gửi sẽ revoke tất cả session của user."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints"
