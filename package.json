{
  "name": "starter-be",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:prod:build": "node ./scripts/docker/run.js prod build",
    "docker:prod:up": "node ./scripts/docker/run.js prod up -d",
    "docker:prod:down": "node ./scripts/docker/run.js prod down",
    "docker:prod:logs": "node ./scripts/docker/run.js prod logs -f",
    "docker:prod:restart": "node ./scripts/docker/run.js prod restart",
    "docker:prod:clean": "node ./scripts/docker/run.js prod down -v",
    "docker:dev:build": "node ./scripts/docker/run.js dev build",
    "docker:dev:up": "node ./scripts/docker/run.js dev up -d",
    "docker:dev:down": "node ./scripts/docker/run.js dev down",
    "docker:dev:logs": "node ./scripts/docker/run.js dev logs -f",
    "docker:dev:restart": "node ./scripts/docker/run.js dev restart",
    "docker:dev:clean": "node ./scripts/docker/run.js dev down -v",
    "build:prod": "./scripts/build.sh production",
    "build:dev": "./scripts/build.sh development",
    "deploy:prod": "./scripts/deploy.sh production",
    "deploy:dev": "./scripts/deploy.sh development",
    "db:up": "node ./scripts/docker/run.js dev up -d postgres",
    "db:down": "node ./scripts/docker/run.js dev stop postgres",
    "db:logs": "node ./scripts/docker/run.js dev logs -f postgres",
    "db:migrate": "node ./scripts/db/typeorm.js run",
    "db:revert": "node ./scripts/db/typeorm.js revert",
    "db:generate": "node ./scripts/db/typeorm.js generate",
    "db:show": "node ./scripts/db/typeorm.js show",
    "migrate": "npm run db:migrate",
    "migrate:revert": "npm run db:revert",
    "migrate:generate": "npm run db:generate",
    "migrate:show": "npm run db:show",
    "backup:db": "./scripts/backup-db.sh",
    "seed": "./scripts/seed.sh"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "form-data": "^4.0.5",
    "node-xlsx": "^0.24.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
