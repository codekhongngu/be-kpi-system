{
	"info": {
		"_postman_id": "kpi-submission-flow-v2",
		"name": "KPI System - Submission Flow (Auth Ready)",
		"description": "Collection cho luồng báo cáo. Đã cấu hình sẵn Bearer Token và biến môi trường.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Tự động thêm Content-Type cho các request có body",
					"if (['POST', 'PATCH', 'PUT'].includes(pm.request.method)) {",
					"    pm.request.headers.add({key: 'Content-Type', value: 'application/json'});",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "1. Staff - My Assignments",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/my/assignments?status=all&overdue=false",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"my",
						"assignments"
					],
					"query": [
						{
							"key": "status",
							"value": "all",
							"description": "Giá trị: all, unsubmitted, pending, approved, rejected"
						},
						{
							"key": "overdue",
							"value": "false",
							"description": "Nếu là true, chỉ lấy các báo cáo đã quá hạn"
						}
					]
				},
				"description": "Lấy danh sách các báo cáo được giao cho đơn vị của nhân viên hiện tại."
			}
		},
		{
			"name": "2. Staff - Get/Create Submission",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/submissions/assignment/:assignmentId",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"submissions",
						"assignment",
						":assignmentId"
					],
					"variable": [
						{
							"key": "assignmentId",
							"value": "ENTER_ASSIGNMENT_UUID",
							"description": "ID từ API My Assignments"
						}
					]
				},
				"description": "Lấy chi tiết ma trận nhập liệu. Nếu chưa tồn tại, Backend sẽ tự động tạo một bản ghi DRAFT."
			}
		},
		{
			"name": "3. Staff - Patch Cells (Auto-save)",
			"request": {
				"method": "PATCH",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"clientVersion\": 1,\n    \"changes\": [\n        {\n            \"indicatorId\": \"ind-uuid-1\",\n            \"attributeId\": \"attr-uuid-1\",\n            \"valueText\": \"1500000\",\n            \"valueNumber\": 1500000\n        },\n        {\n            \"indicatorId\": \"ind-uuid-2\",\n            \"attributeId\": \"attr-uuid-2\",\n            \"valueText\": \"Ghi chú giải trình\",\n            \"valueNumber\": null\n        }\n    ]\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/submissions/:id/cells",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"submissions",
						":id",
						"cells"
					],
					"variable": [
						{
							"key": "id",
							"value": "ENTER_SUBMISSION_UUID",
							"description": "ID từ API Get Submission"
						}
					]
				},
				"description": "API lưu nháp tự động. 'clientVersion' dùng để xử lý xung đột dữ liệu (Conflict 412)."
			}
		},
		{
			"name": "4. Staff - Submit Report",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"note\": \"Hoàn tất báo cáo số liệu quý 2\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/submissions/:id/submit",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"submissions",
						":id",
						"submit"
					],
					"variable": [
						{
							"key": "id",
							"value": "ENTER_SUBMISSION_UUID"
						}
					]
				},
				"description": "Gửi báo cáo lên cấp trên. Sau khi gọi, trạng thái chuyển sang PENDING và dữ liệu bị khóa."
			}
		},
		{
			"name": "5. Staff - Cancel Submit",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/submissions/:id/cancel-submit",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"submissions",
						":id",
						"cancel-submit"
					],
					"variable": [
						{
							"key": "id",
							"value": "ENTER_SUBMISSION_UUID"
						}
					]
				},
				"description": "Thu hồi báo cáo đã nộp khi đang ở trạng thái PENDING. Trạng thái chuyển về DRAFT."
			}
		},
		{
			"name": "6. Admin - Approve Report",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"submissionId\": \"ENTER_SUBMISSION_UUID\",\n    \"note\": \"Dữ liệu đầy đủ và chính xác, phê duyệt.\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/approvals/approve",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"approvals",
						"approve"
					]
				}
			}
		},
		{
			"name": "7. Admin - Reject Report",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"submissionId\": \"ENTER_SUBMISSION_UUID\",\n    \"reason\": \"Số liệu mục B chưa khớp với chứng từ gốc, yêu cầu kiểm tra lại.\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/approvals/reject",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"approvals",
						"reject"
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "YOUR_JWT_TOKEN_HERE",
			"type": "string"
		}
	]
}
