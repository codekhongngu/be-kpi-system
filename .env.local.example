# Cấu hình cho Node.js app chạy LOCAL (không trong Docker)
# Kết nối đến PostgreSQL đang chạy trong Docker container

# App Configuration
PORT=5000
NODE_ENV=development

# Database Configuration - Kết nối từ HOST đến Docker container
# DB_HOST phải là localhost (không phải 'postgres') vì app chạy ngoài Docker
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=starter_db
DB_SYNCHRONIZE=true
DB_LOGGING=true
